{
  "name": "troy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/public dist/public",
    "start": "tsx src/index.ts run",
    "discord": "tsx src/index.ts discord",
    "web": "tsx src/index.ts web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "tsc && node --test 'dist/*.test.js'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.1",
    "eslint": "^9.39.2",
    "knip": "^5.86.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.55.0"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "googleapis": "^171.4.0",
    "node-html-markdown": "^2.0.0",
    "winston": "^3.19.0"
  }
}
